lemma P4_non_transferability:
  all-traces
  "∀ H aid K payee asset val cid #s.
    (Settled( H, aid, K, payee, asset, val, cid ) @ #s) ⇒
    (∃ #a. Authorized( H, aid, payee, asset, val, cid ) @ #a)"
/*
guarded formula characterizing all counter-examples:
"∃ H aid K payee asset val cid #s.
  (Settled( H, aid, K, payee, asset, val, cid ) @ #s)
 ∧
  ∀ #a. (Authorized( H, aid, payee, asset, val, cid ) @ #a) ⇒ ⊥"
*/
simplify
solve( !HumanPk( $H, pk(x) ) ▶₁ #s )
  case Register_Human
  solve( !AgentKey( aid, ~sk ) ▶₂ #s )
    case Register_Agent
    solve( NonceUnused( h(h(<cid, $agentId, mandate, asset, payee, val>))
           ) ▶₃ #s )
      case Authorize_ModeA
      solve( !KU( sign(h(<$chainId, $agentId, ~mandate, $asset, $payee, $value
                         >),
                       ~hsk)
             ) @ #vk.1 )
        case Authorize_ModeA
        by contradiction /* from formulas */
      next
        case c_sign
        by solve( !KU( ~hsk ) @ #vk.14 )
      qed
    next
      case Authorize_ModeB
      solve( !KU( sign(h(<$okChain, $agentId, ~p, $okPayee, $okAsset, $okValue
                         >),
                       ~hsk)
             ) @ #vk.1 )
        case c_sign
        by solve( !KU( ~hsk ) @ #vk.14 )
      qed
    qed
  qed
qed

lemma P5_predicate_soundness:
  all-traces
  "∀ H aid K payee asset val cid p #s.
    (SettledB( H, aid, K, payee, asset, val, cid, p ) @ #s) ⇒
    (∃ #d. AdmitB( H, p, aid, payee, asset, val, cid ) @ #d)"
/*
guarded formula characterizing all counter-examples:
"∃ H aid K payee asset val cid p #s.
  (SettledB( H, aid, K, payee, asset, val, cid, p ) @ #s)
 ∧
  ∀ #d. (AdmitB( H, p, aid, payee, asset, val, cid ) @ #d) ⇒ ⊥"
*/
simplify
solve( !PredPk( p, pk(x) ) ▶₁ #s )
  case Authorize_ModeB
  solve( !AgentKey( aid, ~sk ) ▶₂ #s )
    case Register_Agent
    solve( !Admissible( H, ~p, $agentId, payee, asset, val, cid ) ▶₃ #s )
      case Authorize_ModeB
      by contradiction /* from formulas */
    qed
  qed
qed

