# Lightsail backend + Anvil (chain id 31337). Copy to repo root as `.env`.
# Vercel frontend: see deploy/lightsail/vercel.env.example

NODE_ENV=production

# --- Anvil (clb-acel-anvil.service binds 0.0.0.0:8545 for demo) ---
CHAIN_ID=31337
RPC_URL=http://127.0.0.1:8545
# Public HTTP RPC (optional): http://18.142.200.48:8545
# Public HTTPS RPC (after setup-https.sh): https://18.142.200.48.nip.io/rpc
# Anvil account #0 — local demo only, never use on a public chain
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
USER_TEST_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
SHOPPING_AGENT_PRIVATE_KEY=0x59c6995e998f97a5a0044966f094538e9dcaa4cf4688bfc8d48a5a3fd9e6ecb9
MERCHANT_AGENT_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804d5f413aa

# After: bash scripts/deploy-anvil-contracts.sh
AUDIT_ANCHOR_ADDRESS=
ERC8004_REGISTRY_ADDRESS=
PREDICATE_GUARD_ADDRESS=

# --- x402 (local facilitator matches Anvil) ---
X402_FACILITATOR_MODE=local
X402_NETWORK=anvil
X402_ASSET=ETH
X402_PRICE=2.00

# --- Data plane ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require
DATABASE_SSL=true
AWS_REGION=us-east-1
S3_BUCKET=clb-acel-evidence
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Orchestrator (required for multi-process backend) ---
ORCHESTRATOR_TRANSPORT=http

# Loopback URLs on Lightsail (nginx HTTPS paths — see setup-https.sh)
AGENT_ORCHESTRATOR_PORT=4000
AGENT_ORCHESTRATOR_URL=http://127.0.0.1:4000
EVIDENCE_SERVICE_PORT=4001
EVIDENCE_SERVICE_URL=http://127.0.0.1:4001
IDENTITY_SERVICE_PORT=4002
IDENTITY_SERVICE_URL=http://127.0.0.1:4002
MANDATE_SERVICE_PORT=4003
MANDATE_SERVICE_URL=http://127.0.0.1:4003
MERCHANT_AGENT_PORT=4004
MERCHANT_AGENT_URL=http://127.0.0.1:4004
VERIFIER_SERVICE_PORT=4005
VERIFIER_SERVICE_URL=http://127.0.0.1:4005
ATTACK_SIMULATOR_PORT=4006
ATTACK_SIMULATOR_URL=http://127.0.0.1:4006

# --- Python scorer (optional; requires uv on PATH) ---
RISK_SCORER=typescript
# RISK_SCORER=python

# --- LLM (optional) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=

EVIDENCE_ENCRYPTION_KEY=
JWT_SECRET=
