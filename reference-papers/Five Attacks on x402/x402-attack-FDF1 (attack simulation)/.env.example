# x402-attack reproducibility configuration
#
# Copy to `.env` and fill only the sections you need. Local Hardhat runs do
# not require live endpoint URLs or API keys.

# ---------------------------------------------------------------------------
# Shared local-chain options
# ---------------------------------------------------------------------------

# Optional. Used by Attack I-A if you run Hardhat on a non-default port.
# ATTACK1_RPC_URL=http://127.0.0.1:8545

# Optional. Keep wide for long local sweeps so test payments do not expire.
# X402_AUTH_VALIDITY_SECONDS=2592000

# ---------------------------------------------------------------------------
# Attack I-A: local revert-grant / finality sweep
# ---------------------------------------------------------------------------

# The paper-facing artifact uses the defaults below:
# 5,000 requests per main condition, 5,000 control requests, 16 relayers,
# and T_b in {2,4,12}s.

# ATTACK1_REQUESTS=5000
# ATTACK1_CONTROL_REQUESTS=5000
# ATTACK1_BLOCK_TIMES=2,4,12
# ATTACK1_CONCURRENCY=32
# ATTACK1_SETTLEMENT_RELAYER_COUNT=16
# ATTACK1_MAX_OUTSTANDING_SETTLEMENTS=32
# ATTACK1_LIMIT_CONFIGS=0

# ---------------------------------------------------------------------------
# Attack I-B: live Base Sepolia settlement-preemption scripts
# ---------------------------------------------------------------------------

# run-eip3009-frontrun.js reads TARGET_URL from the environment.
# Both Attack I-B scripts still use an in-file ALICE_PRIVATE_KEY placeholder;
# edit that constant to a disposable Base Sepolia test wallet before running.

# TARGET_URL=https://<your-x402-endpoint>/...

# ---------------------------------------------------------------------------
# Live testnet client wallet
# ---------------------------------------------------------------------------

# Used by src/testnet-client/run-dgr-1000.js and run-multi-server.js.
# Use a disposable Base Sepolia wallet only.

PRIVATE_KEY=0x<PASTE_64_HEX_BASE_SEPOLIA_TEST_KEY_HERE>
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ---------------------------------------------------------------------------
# Live endpoint slots
# ---------------------------------------------------------------------------

# Endpoint 1: typically a GET endpoint using x-payment.
ENDPOINT_1_URL=https://<your-x402-endpoint-1>/...
ENDPOINT_1_PAY_TO=0x<42-hex-merchant-address>
ENDPOINT_1_AMOUNT=100
ENDPOINT_1_METHOD=GET
ENDPOINT_1_HEADER_NAME=x-payment
# ENDPOINT_1_BODY=

# Endpoint 2: typically a JSON-RPC style POST endpoint using payment-signature.
ENDPOINT_2_URL=https://<your-x402-endpoint-2>/...
ENDPOINT_2_PAY_TO=0x<42-hex-merchant-address>
ENDPOINT_2_AMOUNT=1000
ENDPOINT_2_METHOD=POST
ENDPOINT_2_HEADER_NAME=payment-signature
ENDPOINT_2_BODY={"jsonrpc":"2.0","method":"eth_blockNumber","params":[],"id":1}

# ---------------------------------------------------------------------------
# Attack III: local proxy/cache harness
# ---------------------------------------------------------------------------

# Optional pinned images. The defaults in src/attack3/run-experiment.js match
# the committed Attack III artifact.
# ATTACK3_NGINX_IMAGE=nginx@sha256:7150b3a39203cb5bee612ff4a9d18774f8c7caf6399d6e8985e97e28eb751c18
# ATTACK3_CADDY_IMAGE=caddy@sha256:1e40b251ca9639ead7b5cd2cedcc8765adfbabb99450fe23f130eefabf50f4bc

# ---------------------------------------------------------------------------
# Attack IV: LLM server-selection experiments
# ---------------------------------------------------------------------------

# Provider: minimax, openai, or anthropic.
# ATTACK4_PROVIDER=minimax
# ATTACK4_MODEL=<override model name>
# ATTACK4_OUTPUT=results/attack4/custom-output.json
# ATTACK4_OUTPUT_SUFFIX=custom

# MiniMax
# MINIMAX_API_KEY=<MiniMax API key>
# MINIMAX_MODEL=MiniMax-M2.7
# MINIMAX_API_URL=https://api.minimaxi.chat/v1/chat/completions

# OpenAI-compatible chat-completions endpoint
# OPENAI_API_KEY=<OpenAI API key>
# OPENAI_MODEL=gpt-5.3-chat-latest
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Anthropic Messages API
# ANTHROPIC_API_KEY=<Anthropic API key>
# ANTHROPIC_MODEL=claude-sonnet-4-5
# ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages

# Bazaar concentration helper. Set to 1 only if you want to print raw domains.
# SHOW_ATTACK4_DOMAINS=0
