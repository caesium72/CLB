{
  "name": "clb-acel",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "bun run --filter @clb-acel/web-demo dev",
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "e2e:phase2": "bun run scripts/e2e-phase2.ts",
    "e2e:phase3": "bun run scripts/e2e-phase3.ts",
    "e2e:phase4": "bun run scripts/e2e-phase4.ts",
    "e2e:phase4b": "bun run scripts/e2e-phase4b.ts",
    "e2e:phase5": "bun run scripts/e2e-phase5.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@clb-acel/agent-orchestrator": "workspace:*",
    "@clb-acel/attack-core": "workspace:*",
    "@clb-acel/clb-core": "workspace:*",
    "@clb-acel/predicate-adapter": "workspace:*",
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "bun-types": "^1.3.14",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  }
}
