# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# Service ports / URLs (Mode A)
AGENT_ORCHESTRATOR_PORT=4000
AGENT_ORCHESTRATOR_URL=http://localhost:4000
EVIDENCE_SERVICE_URL=http://localhost:4001
EVIDENCE_SERVICE_PORT=4001
IDENTITY_SERVICE_PORT=4002
MANDATE_SERVICE_PORT=4003
MERCHANT_AGENT_PORT=4004
MERCHANT_AGENT_URL=http://localhost:4004
VERIFIER_SERVICE_PORT=4005
ATTACK_SIMULATOR_PORT=4006
ATTACK_SIMULATOR_URL=http://localhost:4006

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require
DATABASE_SSL=true

# Object storage (AWS S3)
AWS_REGION=us-east-1
S3_BUCKET=clb-acel-evidence
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: set only for local MinIO (when docker minio is uncommented)
# S3_ENDPOINT=http://localhost:9000

# Chain
CHAIN_ID=31337
NEXT_PUBLIC_DEMO_CHAIN_ID=31337
RPC_URL=http://127.0.0.1:8545
RPC_URL_BASE_SEPOLIA=
DEPLOYER_PRIVATE_KEY=
USER_TEST_PRIVATE_KEY=
SHOPPING_AGENT_PRIVATE_KEY=
MERCHANT_AGENT_PRIVATE_KEY=

# Contracts
AUDIT_ANCHOR_ADDRESS=
ERC8004_REGISTRY_ADDRESS=
PREDICATE_GUARD_ADDRESS=

# x402
X402_FACILITATOR_URL=
X402_FACILITATOR_MODE=local
X402_NETWORK=base-sepolia
X402_ASSET=USDC
X402_ASSET_ADDRESS=
X402_PAY_TO_ADDRESS=
X402_PRICE=2.00

# Orchestrator / services
ORCHESTRATOR_TRANSPORT=in-process
IDENTITY_SERVICE_URL=http://localhost:4002
MANDATE_SERVICE_URL=http://localhost:4003
VERIFIER_SERVICE_URL=http://localhost:4005
RISK_SCORER=typescript
# Set to python only when uv is installed (https://docs.astral.sh/uv/)

# LLM
OPENAI_API_KEY=
GROK_API_KEY=
LLM_PROVIDER=openai

# Security
EVIDENCE_ENCRYPTION_KEY=
JWT_SECRET=
